{
  "name": "zkmemoryauthorization",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter @zkma/admin-ui dev",
    "dev:landing": "pnpm --filter @zkma/landing dev",
    "build": "pnpm --filter @zkma/admin-ui build",
    "build:landing": "pnpm --filter @zkma/landing build",
    "test": "pnpm -r --if-present test",
    "typecheck": "pnpm -r --if-present typecheck",
    "seed:memories": "pnpm --filter @zkma/gateway exec tsx ../../scripts/seed-memories.ts"
  },
  "packageManager": "pnpm@9.0.0"
}
