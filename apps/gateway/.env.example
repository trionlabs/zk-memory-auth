# Gateway env. Copy to .env (gitignored) and source in your shell, or export
# before running `pnpm dev`. tsx does not auto-load .env files; use direnv,
# `set -a; source .env; set +a`, or one of the dotenv-cli wrappers.

# === required for production-style runs ===

# The OAuth client_id Google issued to your zkma platform. The gateway pins
# publicInputs.expected_aud to this; without it every search returns 403
# `aud mismatch`. MUST equal `NEXT_PUBLIC_GOOGLE_CLIENT_ID` in the admin-ui.
ZKMA_EXPECTED_AUD=

# === networking ===

PORT=8787
SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
MEM0_BASE_URL=http://localhost:8888
MEM0_AGENT_ID=zkma

# === pins (defaults are fine for Google + a 7-day proof rotation) ===

ZKMA_EXPECTED_ISS=https://accounts.google.com
ZKMA_IAT_MAX_AGE_SECS=604800

# Per-deployment domain separator on the signed challenge. Pick a unique
# value per environment so a sig issued for `prod-eu` cannot be replayed
# against `prod-us`. Empty string is rejected at startup.
ZKMA_GATEWAY_DOMAIN=zkma:gateway:dev

# Where the gateway loads the bb.js verification key from. Default points at
# circuits/zkma-auth/target/zkma_auth.json relative to the source.
# ZKMA_CIRCUIT_PATH=

# === test escape hatches (DO NOT set in prod) ===

# =1 to skip the live JWKS fetch (pin to ZKMA_EXTRA_MODULI only).
# ZKMA_SKIP_JWKS=
# Comma-separated hex moduli to allowlist in addition to JWKS.
# ZKMA_EXTRA_MODULI=
# =1 to skip the bb.js cryptographic check. JWKS + claim pins still run.
# ZKMA_SKIP_PROOF_VERIFY=

# === optional ===

# If your mem0 instance is configured with auth, set the bearer token here.
# MEM0_API_KEY=
