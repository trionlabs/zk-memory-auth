# Copy to .env.local and fill in. Next.js auto-exposes NEXT_PUBLIC_* to the browser bundle.

# Google OAuth Web client_id used by Google Identity Services (GIS) on /refresh.
# Get one at https://console.cloud.google.com/apis/credentials -> Create Credentials
# -> OAuth client ID -> Application type: Web application. Add http://localhost:3030
# (and your production origin) under "Authorized JavaScript origins". You do NOT
# need a client_secret for ID-token-only flow.
#
# Once set, the gateway must also be started with ZKMA_EXPECTED_AUD set to the
# same value, because the JWT's `aud` claim equals this client_id and the
# gateway pins it.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
